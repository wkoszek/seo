#!/usr/bin/env python3
"""
SEO Tool for Bay Area Polish Group

Commands:
    seo init      Set up Google Cloud credentials
    seo auth      Authenticate with Google
    seo status    Check configuration
    seo sites     List verified sites
    seo fetch     Fetch raw GSC data to disk
    seo render    Render reports from fetched data
    seo suggest   Suggest new pages to create
    seo ping      Ping Google with all sitemaps
"""

import argparse
import sys
from pathlib import Path

# Add script directory to path for imports
sys.path.insert(0, str(Path(__file__).parent))

from seo_common import REPORTS_DIR


def main():
    parser = argparse.ArgumentParser(description="SEO Tool")
    sub = parser.add_subparsers(dest="cmd")

    # init
    sub.add_parser("init", help="Set up Google Cloud credentials")

    # auth
    p = sub.add_parser("auth", help="Authenticate with Google")
    p.add_argument("--force", action="store_true", help="Force re-authentication")

    # status
    sub.add_parser("status", help="Check configuration")

    # sites
    sub.add_parser("sites", help="List verified sites")

    # fetch (was: report)
    p = sub.add_parser("fetch", help="Fetch raw GSC data to disk")
    p.add_argument("--days", type=int, default=30, help="Days to analyze (default: 30)")
    p.add_argument("--full", action="store_true", help="Inspect all URLs (slow, run overnight)")
    p.add_argument("--output", default=str(REPORTS_DIR), help="Output directory")

    # render (was: inspect)
    p = sub.add_parser("render", help="Render reports from fetched data")
    p.add_argument("--data", help="Data directory (default: latest fetch)")
    p.add_argument("--verbose", "-v", action="store_true", help="Show all URLs")

    # suggest
    p = sub.add_parser("suggest", help="Suggest new pages to create from GSC data")
    p.add_argument("--data", help="Data directory (default: latest fetch)")
    p.add_argument("--min-impressions", type=int, default=50, dest="min_impressions",
                   help="Minimum impressions threshold (default: 50)")

    # ping
    sub.add_parser("ping", help="Ping Google with all sitemaps")

    # indexnow
    p = sub.add_parser("indexnow", help="Generate / show the shared IndexNow key")
    p.add_argument("--force", action="store_true", help="Regenerate even if key exists")

    # sitemap
    p = sub.add_parser("sitemap", help="Submit sitemap to Google Search Console")
    p.add_argument("domain", help="Domain to submit sitemap for (e.g. rustjob.com)")
    p.add_argument("--domain-property", action="store_true",
                   help="Use sc-domain: property instead of URL-prefix")

    # verify
    p = sub.add_parser("verify", help="Verify site ownership and add to Search Console")
    p.add_argument("domain", help="Domain to verify (e.g. rustjob.com)")
    p.add_argument("--method", default="analytics",
                   choices=["analytics", "dns", "file", "meta"],
                   help="Verification method (default: analytics)")
    p.add_argument("--confirm", action="store_true",
                   help="Complete verification after placing the token")

    # install
    p = sub.add_parser("install", help="Create GA4 property and write gtag snippet")
    p.add_argument("domain", help="Domain to install GA on (e.g. example.com)")
    p.add_argument("--account", help="GA account ID (auto-detected if only one)")
    p.add_argument("--output", default=".", help="Output directory for snippet file (default: .)")

    args = parser.parse_args()

    if not args.cmd:
        parser.print_help()
        print("\nCommands:")
        print("  seo init      Set up Google Cloud credentials")
        print("  seo auth      Authenticate with Google")
        print("  seo status    Check configuration")
        print("  seo sites     List verified sites")
        print("  seo fetch     Fetch raw GSC data to disk")
        print("  seo render    Render reports from fetched data")
        print("  seo suggest   Suggest new pages to create")
        print("  seo ping      Ping Google with all sitemaps")
        print("  seo sitemap   Submit sitemap to Google Search Console")
        print("  seo verify    Verify site ownership and add to Search Console")
        print("  seo install   Create GA4 property and write gtag snippet")
        return 0

    # Import and run command
    if args.cmd == "init":
        from seo_init import cmd_init
        return cmd_init(args)
    elif args.cmd == "auth":
        from seo_auth import cmd_auth
        return cmd_auth(args)
    elif args.cmd == "status":
        from seo_status import cmd_status
        return cmd_status(args)
    elif args.cmd == "sites":
        from seo_sites import cmd_sites
        return cmd_sites(args)
    elif args.cmd == "fetch":
        from seo_fetch import cmd_fetch
        return cmd_fetch(args)
    elif args.cmd == "render":
        from seo_render import cmd_render
        return cmd_render(args)
    elif args.cmd == "suggest":
        from seo_suggest import cmd_suggest
        return cmd_suggest(args)
    elif args.cmd == "ping":
        from seo_ping import cmd_ping
        return cmd_ping(args)
    elif args.cmd == "indexnow":
        from seo_indexnow import cmd_indexnow
        return cmd_indexnow(args)
    elif args.cmd == "sitemap":
        from seo_sitemap import cmd_sitemap
        return cmd_sitemap(args)
    elif args.cmd == "verify":
        from seo_verify import cmd_verify
        return cmd_verify(args)
    elif args.cmd == "install":
        from seo_install import cmd_install
        return cmd_install(args)

    return 1


if __name__ == "__main__":
    sys.exit(main())
